# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/project_aegis

# ── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_hex_string_for_access_tokens
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_string_for_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Google OAuth (optional — omit to skip OAuth setup) ──
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Client / CORS ───────────────────────────────────────
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ── Encryption (AES-256-GCM for sensitive DB fields) ────
ENCRYPTION_KEY=replace_with_64_char_hex_string_for_aes256

# ── Email (SMTP via Resend or any provider) ─────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=your_smtp_api_key
EMAIL_FROM=noreply@yourdomain.com

# ── Sentry (error tracking) ─────────────────────────────
SENTRY_DSN=https://your_sentry_dsn_here

# ── OpenAI / AI Coach ────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── CORS (comma-separated allowed origins) ───────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Storage ───────────────────────────────────────────────
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
LOCAL_UPLOAD_DIR=./uploads
LOCAL_UPLOAD_URL=http://localhost:5000/uploads
